      <CheatEntries>
        <CheatEntry>
          <ID>336</ID>
          <Description>"no bodlily damage"</Description>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>// rsi=88 = base character stat pointer

[ENABLE]

aobscanmodule(BodilyDamage,WHGame.DLL,8B 86 D0 00 00 00 89 45)
registersymbol(BodilyDamage)

alloc(newmem,$1000,BodilyDamage)

label(return)

newmem:
cmp dword ptr[rsi+88],bStatsPtr2
jne short @f
lea rsi,[rsi]
and dword ptr [rsi+000000D0],0
@@:
  mov eax,[rsi+000000D0]
  jmp return

BodilyDamage:
  jmp newmem
  nop
return:

[DISABLE]

BodilyDamage:
  db 8B 86 D0 00 00 00

unregistersymbol(BodilyDamage)
dealloc(newmem)


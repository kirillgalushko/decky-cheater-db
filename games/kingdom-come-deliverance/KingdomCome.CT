        <CheatEntry>
          <ID>202</ID>
          <Description>"god mode"</Description>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>[ENABLE]

aobscanmodule(gmKCD1,WHGame.DLL,F3 0F 11 B4 B3 04 05 00 00)
registersymbol(gmKCD1)

alloc(newmem,$1000,gmKCD1)

label(return)

newmem:
cmp rsi,1
jne short @f
comiss xmm6,[KCDFH+c]
jb short @f
cmp dword[rbx+28],cccc
jb short @f
cmp dword[rbx+20],a67
je short @f
//cmp [rbx+20],8a9
//jne short @f
//movss xmm6,[KCDFH+c] // reduce stamina of others
@@:
cmp [rbx+20],a53
jne bpken
  vmaxss xmm6,xmm7,xmm9
  cmp rsi,3
  jne short @f
mulss xmm6,[KCDFH+8]
  @@:
  movss [rbx+rsi*4+00000504],xmm6
  jmp return
@@:
cmp rsi,0
jne short @f
comiss xmm6,[KCDFH+4]
jb short @f
movss xmm6,[KCDFH+4]
bpken:
lea rbx,[rbx]
  movss [rbx+rsi*4+00000504],xmm6
  jmp return
align 8
KCDFH:
dd (float)100 (float).1 (float).75 (float)1

gmKCD1:
  jmp newmem
  nop 4
return:

[DISABLE]

gmKCD1:
  db F3 0F 11 B4 B3 04 05 00 00

unregistersymbol(gmKCD1)
dealloc(newmem)


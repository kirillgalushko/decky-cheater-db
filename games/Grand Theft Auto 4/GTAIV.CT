[ENABLE]

aobscanmodule(health,GTAIV.exe,D9 81 9C 0E 00 00) // should be unique
alloc(newmem,$1000)

label(code)
label(return)
label(fullhealth)

newmem:
fld [fullhealth]
fstp [ecx+00000E9C]
code:
  fld dword ptr [ecx+00000E9C]
  jmp return
fullhealth:
dd (float)200

health:
  jmp newmem
  nop
return:
registersymbol(health)

[DISABLE]

health:
  db D9 81 9C 0E 00 00

unregistersymbol(health)
dealloc(newmem)


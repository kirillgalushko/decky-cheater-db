      <ID>338</ID>
      <Description>"Reputation Pointers 1 = 100%"</Description>
      <Options moHideChildren="1"/>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript>[ENABLE]

aobscanmodule(Reputation,WHGame.DLL,4C 8B 73 08 49 8B D6)
registersymbol(Reputation)
alloc(newmem,$1000,Reputation)

registersymbol(RepPntrs)
label(RepPntrs)
label(return)

newmem:
mov rcx,RepPntrs
cmp [rcx-8],rcx
jae short @f
mov [rcx-8],rcx
@@:
cmp rax,65
ja @f
and rdx,0
mov [rcx-10],rdx
@@:
mov rdx,[rcx-10]
and rdx,7f
mov [rcx+rdx*8],rbx
inc rdx
mov [rcx-10],rdx
  mov r14,[rbx+08]
  mov rdx,r14
  jmp return
align 8
dq 0 RepPntrs
RepPntrs:
dq 0


Reputation:
  jmp newmem
  nop 2
return:

[DISABLE]

Reputation:
  db 4C 8B 73 08 49 8B D6

unregistersymbol(RepPntrs)
unregistersymbol(Reputation)
dealloc(newmem)

